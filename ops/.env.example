# ops/.env.example — minimal config for the pixel-server monitoring toolkit.
# Copy to ops/.env (gitignored), edit, then source before running ops-start.sh.
#
#   cp ops/.env.example ops/.env && $EDITOR ops/.env
#   set -a; . ops/.env; set +a
#   bash ops/bin/ops-start.sh

# ---------------------------------------------------------------------------
# REQUIRED: pixel server base URL.
# 127.0.0.1:9000 is correct ONLY when ops/ runs on the SAME VPS as the server
# (deploy-prod publishes nginx on host port 9000).  Remote node → public URL.
# ---------------------------------------------------------------------------
PIXEL_BASE=http://127.0.0.1:9000

# ---------------------------------------------------------------------------
# RECOMMENDED: Docker Compose auto-discovery (set to your compose project name).
# When set, the monitor discovers containers by prefix and reports depth without
# requiring an explicit OPS_DOCKER_CONTAINERS list.
# ---------------------------------------------------------------------------
# OPS_DOCKER_COMPOSE_PROJECT=playable_tracking

# ---------------------------------------------------------------------------
# OPTIONAL: explicit container list (overrides compose-project discovery).
# ---------------------------------------------------------------------------
# OPS_DOCKER_CONTAINERS="nginx app redis worker"

# ---------------------------------------------------------------------------
# OPTIONAL: container name prefix filter (alternative to explicit list).
# ---------------------------------------------------------------------------
# OPS_DOCKER_CONTAINER_PREFIXES="pixel- playable-"

# ---------------------------------------------------------------------------
# OPTIONAL: Redis depth via docker exec (prod redis has no published host port).
# ---------------------------------------------------------------------------
# OPS_REDIS_CONTAINER=redis
# OPS_REDIS_QUEUE_KEY=pixel:queue

# ---------------------------------------------------------------------------
# PIXEL PROBE: point at a valid synthetic event so a real ingest check runs.
# A bare /p.gif returns HTTP 400 by design; the probe below avoids that.
# ---------------------------------------------------------------------------
OPS_PIXEL_EXPECT_CODE=200
OPS_PIXEL_PROBE_PATH="/p.gif?event=ops_healthcheck&game=ops&source=monitor"

# ---------------------------------------------------------------------------
# CAPACITY / LOADTEST SAFETY: off by default; never auto-runs on deploy.
# stress.sh refuses unless LOADTEST_ENABLED=1; capacity-loop only schedules a
# run when CAPACITY_ENABLED=1; production target also requires ALLOW_PROD_LOADTEST=1.
# ---------------------------------------------------------------------------
CAPACITY_ENABLED=0
LOADTEST_ENABLED=0
MAX_RPS=500
MAX_CONCURRENCY=100
LOADTEST_ENV=production
ALLOW_PROD_LOADTEST=0

# ---------------------------------------------------------------------------
# OPTIONAL: show all discovered containers in dashboard even if not in the
# declared list (0 = quiet / 1 = verbose).
# ---------------------------------------------------------------------------
OPS_DOCKER_LOG_ALL_VISIBLE=0

# ---------------------------------------------------------------------------
# OPTIONAL tuning (defaults shown — uncomment to override):
# ---------------------------------------------------------------------------
# MONITOR_INTERVAL=30
# LOGCOLLECT_INTERVAL=60
# LOGCOLLECT_DOCKER_SINCE=10m
# LOGCOLLECT_DOCKER_TAIL=500
# HIGH_LATENCY_MS=500
# DASH_REFRESH=5
