# ops/.env.example — minimal config for the pixel-server monitoring toolkit.
# Copy to ops/.env (gitignored), edit, then source before running ops-start.sh.
#
#   cp ops/.env.example ops/.env && $EDITOR ops/.env
#   set -a; . ops/.env; set +a
#   bash ops/bin/ops-start.sh

# ---------------------------------------------------------------------------
# REQUIRED: pixel server base URL.
# 127.0.0.1:9000 is correct ONLY when ops/ runs on the SAME VPS as the server
# (deploy-prod publishes nginx on host port 9000).  Remote node → public URL.
# ---------------------------------------------------------------------------
PIXEL_BASE=http://127.0.0.1:9000

# ---------------------------------------------------------------------------
# RECOMMENDED: Docker Compose auto-discovery (set to your compose project name).
# When set, the monitor discovers containers by prefix and reports depth without
# requiring an explicit OPS_DOCKER_CONTAINERS list.
# ---------------------------------------------------------------------------
# OPS_DOCKER_COMPOSE_PROJECT=playable_tracking

# ---------------------------------------------------------------------------
# OPTIONAL: explicit container list (overrides compose-project discovery).
# ---------------------------------------------------------------------------
# OPS_DOCKER_CONTAINERS="nginx app redis worker"

# ---------------------------------------------------------------------------
# OPTIONAL: container name prefix filter (alternative to explicit list).
# ---------------------------------------------------------------------------
# OPS_DOCKER_CONTAINER_PREFIXES="pixel- playable-"

# ---------------------------------------------------------------------------
# OPTIONAL: Redis depth via docker exec (prod redis has no published host port).
# ---------------------------------------------------------------------------
# OPS_REDIS_CONTAINER=redis
# OPS_REDIS_QUEUE_KEY=pixel:queue

# ---------------------------------------------------------------------------
# HTTP PROBES: disabled by default so ops does not create /health or
# ops_healthcheck entries in nginx/client logs. Enable only when needed.
# ---------------------------------------------------------------------------
OPS_HEALTH_PROBE_ENABLED=0
OPS_PIXEL_PROBE_ENABLED=0
# OPS_PIXEL_EXPECT_CODE=200
# OPS_PIXEL_PROBE_PATH="/p.gif?e=interaction&sid=ops_healthcheck&env=test&event_params=%7B%22name%22%3A%22ops_healthcheck%22%7D"

# ---------------------------------------------------------------------------
# CAPACITY / LOADTEST SAFETY: off by default; never auto-runs on deploy.
# stress.sh refuses unless LOADTEST_ENABLED=1; capacity-loop only schedules a
# run when CAPACITY_ENABLED=1; production target also requires ALLOW_PROD_LOADTEST=1.
# ---------------------------------------------------------------------------
CAPACITY_ENABLED=0
LOADTEST_ENABLED=0
MAX_RPS=500
MAX_CONCURRENCY=100
LOADTEST_ENV=production
ALLOW_PROD_LOADTEST=0

# ---------------------------------------------------------------------------
# OPTIONAL: show all discovered containers in dashboard even if not in the
# declared list (0 = quiet / 1 = verbose).
# ---------------------------------------------------------------------------
OPS_DOCKER_LOG_ALL_VISIBLE=0

# ---------------------------------------------------------------------------
# OPTIONAL tuning (defaults shown — uncomment to override):
# ---------------------------------------------------------------------------
# MONITOR_INTERVAL=30
# LOGCOLLECT_INTERVAL=60
# REDIS_DEDUPE_TTL_SECONDS=86400
# Docker logs default to the whole local ops day: 00:00 through next-day 00:00.
# OPS_LOG_DATE=2026-06-09
# LOGCOLLECT_DOCKER_SINCE=2026-06-09T00:00:00+07:00
# LOGCOLLECT_DOCKER_UNTIL=2026-06-10T00:00:00+07:00
# LOGCOLLECT_DOCKER_TAIL=all
# HIGH_LATENCY_MS=500
# DASH_REFRESH=5

# ---------------------------------------------------------------------------
# BIGQUERY LOG EXPORT (disabled by default — safe to leave off indefinitely).
# Set OPS_BQ_EXPORT_ENABLED=1 only after completing the BigQuery setup steps
# in ops/README.md (IAM, partitioned tables, service-account key on VPS).
# All vars below are optional when the exporter is disabled.
# ---------------------------------------------------------------------------
OPS_BQ_EXPORT_ENABLED=0

# BigQuery project + dataset + table targets.
# OPS_BQ_PROJECT_ID=                                    # GCP project ID (canonical; OPS_BQ_PROJECT accepted as fallback)
# OPS_BQ_DATASET=pixel_ops_logs
# OPS_BQ_NGINX_TABLE=nginx_requests
# OPS_BQ_REDIS_TABLE=redis_metrics

# Export schedule + batch size.
# OPS_BQ_EXPORT_INTERVAL_SECONDS=300
# OPS_BQ_EXPORT_BATCH_SIZE=5000

# Service-account key file (absolute path on the VPS — NEVER commit this file).
# GOOGLE_APPLICATION_CREDENTIALS=

# Source containers / log paths the exporter reads from.
# OPS_NGINX_CONTAINER=
# OPS_NGINX_ACCESS_LOG_PATH=
# OPS_NGINX_ERROR_LOG_PATH=
# OPS_REDIS_CONTAINER=
# OPS_REDIS_QUEUE_KEY=

# Privacy controls (recommended values shown as defaults).
# OPS_LOG_HASH_IP=1                                     # SHA-256-hash client IP before export
# OPS_LOG_INCLUDE_QUERY=1                               # include query-string (campaign/platform analysis)
# OPS_LOG_QUERY_ALLOWLIST="e pid sid playableId platform camp campaign_raw env"   # pixel server params; space-separated
# OPS_LOG_DROP_HEADERS=1                                # strip User-Agent/Referer/Cookie before upload

# Table auto-creation (0 = manual schema mgmt / 1 = create partitioned table if missing).
# OPS_BQ_CREATE_TABLES=0
