# ops/.env.example — sample environment for the pixel-server monitoring toolkit.
# Copy to a real env and `source` it (or export the vars) before ops-start.sh.
# DO NOT commit a filled-in copy with real hosts/secrets.
#
#   cp ops/.env.example ops/.env && $EDITOR ops/.env
#   set -a; . ops/.env; set +a
#   bash ops/bin/ops-start.sh

# --- target ---------------------------------------------------------------
# 127.0.0.1:9000 is correct ONLY when ops runs on the SAME VPS as the server
# (the deploy-prod nginx publishes host port 9000). If ops runs remotely, point
# this at the public IP / domain instead, e.g. https://pixel.example.com
PIXEL_BASE=http://127.0.0.1:9000

# --- Docker container monitoring ------------------------------------------
# Space-separated expected containers. When set, a missing/exited/restarting/
# unhealthy container raises an alert. When unset, monitor only LISTS whatever
# containers it discovers and never fails health on a missing name.
OPS_DOCKER_CONTAINERS="pixel-nginx pixel-server pixel-redis pixel-worker"

# --- Redis queue depth ----------------------------------------------------
# Prod redis runs inside a container (not on host localhost), so host redis-cli
# usually can't reach it. Set the container name + queue key to let the monitor
# read depth via `docker exec <container> redis-cli`. The app uses a stream
# (pixel:events); a list key also works (XLEN is tried first, then LLEN).
OPS_REDIS_CONTAINER=pixel-redis
OPS_REDIS_QUEUE_KEY=pixel:events

# --- Pixel endpoint probe -------------------------------------------------
# A bare /p.gif has no query params and returns http 400 BY DESIGN. Point the
# probe at a VALID synthetic event so a real ingest check is performed.
# For a 200 you need: e=<start|interaction|store_trigger|end>, sid, and the
# per-event fields nested in the event_params JSON blob (URL-encoded below:
# {"name":"ops_healthcheck"}). env!=production keeps the row out of the
# production table (lands in pixel_events_ver_2); ops_healthcheck marks it.
OPS_PIXEL_EXPECT_CODE=200
OPS_PIXEL_PROBE_PATH="/p.gif?e=interaction&sid=ops_healthcheck&env=ops&event_params=%7B%22name%22%3A%22ops_healthcheck%22%7D"
# Or specify a full URL (overrides PROBE_PATH):
# OPS_PIXEL_PROBE_URL="http://127.0.0.1:9000/p.gif?e=interaction&sid=ops_healthcheck&env=ops&event_params=%7B%22name%22%3A%22ops_healthcheck%22%7D"

# --- Capacity / loadtest safety -------------------------------------------
# Loadtesting is OFF by default and never auto-runs on deploy. stress.sh refuses
# unless LOADTEST_ENABLED=1; capacity-loop only schedules a run when
# CAPACITY_ENABLED=1. A production target additionally requires both
# LOADTEST_ENV=production AND ALLOW_PROD_LOADTEST=1.
CAPACITY_ENABLED=0
LOADTEST_ENABLED=0
MAX_RPS=500
MAX_CONCURRENCY=100
LOADTEST_ENV=staging
ALLOW_PROD_LOADTEST=0

# --- optional tuning ------------------------------------------------------
# MONITOR_INTERVAL=30
# LOGCOLLECT_INTERVAL=60
# LOGCOLLECT_DOCKER_SINCE=10m
# LOGCOLLECT_DOCKER_TAIL=500
# HIGH_LATENCY_MS=500
# DASH_REFRESH=5
